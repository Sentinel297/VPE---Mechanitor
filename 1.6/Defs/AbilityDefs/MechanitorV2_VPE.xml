<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_MechlinkSTNL</defName>
	<label>Manifest Mechlink</label>
	<description>Uses the power of the psylink to create a mechlink inside the caster's own brain.</description>
	<iconPath>Things/Pawn/Humanlike/Apparel/Mechlink</iconPath>
	<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
	<goodwillImpact>0</goodwillImpact>
	<castTime>30</castTime>
	<durationTime>0</durationTime>
	<targetMode>Self</targetMode>
	<castSound>Psycast_Skip_Pulse</castSound>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_MechanitorV2STNL</path>
			<level>1</level>
			<order>1</order>
			<psyfocusCost>0.07</psyfocusCost>
			<entropyGain>35</entropyGain>
		</li>
		<li Class="VEF.Abilities.AbilityExtension_Hediff">
			<hediff>MechlinkImplant</hediff>
			<bodyPartToApply>Brain</bodyPartToApply>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_EngagedAmbushMode</defName>
	<label>Precept: Ambush</label>
	<description>Psychically hack an experimental ambush precept into a mechanoid, causing it to go invisible until an offensive action is taken. Very effective on worker models, allowing them to continue work while staying mostly undetected.</description>
	<iconPath>UI_Mechanitor/Abilities/Stealth</iconPath>
	<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
	<goodwillImpact>0</goodwillImpact>
	<castTime>30</castTime>
	<durationTime>5800</durationTime>
	<range>12.9</range>
		<chance>0</chance>
	<needsTicking>true</needsTicking>
	<targetingParameters>
		<canTargetLocations>False</canTargetLocations>
		<canTargetSelf>False</canTargetSelf>
		<canTargetAnimals>false</canTargetAnimals>
		<canTargetPawns>True</canTargetPawns>
		<canTargetHumans>False</canTargetHumans>
		<canTargetMechs>True</canTargetMechs>
	</targetingParameters>
	<castSound>Psycast_Skip_Pulse</castSound>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_MechanitorV2STNL</path>
			<level>2</level>
			<order>1</order>
			<psyfocusCost>0.02</psyfocusCost>
			<entropyGain>35</entropyGain>
			<prerequisites>
				<li>VPE_Mechanitor_LightWeight_Summon_STNL</li>
			</prerequisites>
		</li>
		<li Class="VEF.Abilities.AbilityExtension_Hediff">
			<hediff>VPE_EngagedAmbushMode</hediff>
